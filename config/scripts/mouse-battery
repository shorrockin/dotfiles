#!/usr/bin/env bash

# Report Logitech mouse battery via solaar.
#
# solaar queries the device live over HID++, so we get a real percentage and
# fresh data on each poll. The kernel's /sys/class/power_supply/hidpp_battery_*
# only exposes a coarse capacity_level (Full/Normal/Low/Critical) that is
# updated when the mouse pushes an event — typically only on reconnect — so it
# can stay "Full" for days while the battery actually drains.
#
# When the mouse sleeps and disconnects from BT, solaar can't see it. Rather
# than hiding the widget (jarring "vanish on idle, reappear minutes later"),
# we cache the last successful reading and emit a dimmed "stale" state until
# the next live query succeeds.
#
# Requires hardware.logitech.wireless.{enable,enableGraphical} = true in NixOS
# (installs solaar + the udev rules that grant the seat user hidraw access).

ICON="󰍽"
CACHE="${XDG_RUNTIME_DIR:-/tmp}/mouse-battery.last"

emit() {
    local text="$1" tooltip="$2" class="$3"
    echo "{\"text\": \"$text\", \"tooltip\": \"$tooltip\", \"class\": \"$class\"}"
}

class_for() {
    local p="$1"
    if   (( p <= 15 )); then echo critical
    elif (( p <= 30 )); then echo low
    else                     echo ok
    fi
}

out=$(solaar show 2>/dev/null) || true

percent=$(echo "$out" | grep -oE 'Battery: [0-9]+%' | head -n1 | grep -oE '[0-9]+')
model=$(echo "$out"  | awk -F': +' '/^ +Name:/ { print $2; exit }')
status=$(echo "$out" | grep -oE 'BatteryStatus\.[A-Z]+' | head -n1 | cut -d. -f2)

if [[ -n "$percent" ]]; then
    printf '%s\n%s\n%s\n' "$percent" "${model:-}" "${status:-}" > "$CACHE"
    tooltip="${model:-Logitech mouse}\\nBattery: ${percent}%"
    [[ -n "$status" ]] && tooltip="$tooltip\\nStatus: $status"
    emit "$ICON $percent%" "$tooltip" "$(class_for "$percent")"
    exit 0
fi

# Live query failed. Fall back to the last-known reading if we have one, so
# the widget stays visible (dimmed) instead of vanishing on every BT sleep.
if [[ -r "$CACHE" ]]; then
    { IFS= read -r percent; IFS= read -r model; IFS= read -r status; } < "$CACHE"
    if [[ -n "$percent" ]]; then
        tooltip="${model:-Logitech mouse}\\nLast known: ${percent}%\\nMouse asleep / disconnected"
        emit "$ICON $percent%" "$tooltip" "stale"
        exit 0
    fi
fi

emit "" "" "empty"
